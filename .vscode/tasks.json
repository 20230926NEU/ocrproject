{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile",
            "type": "shell",
            "command": "javac",
            "args": [
                "--module-path",
                "/home/kagit/javafx-sdk-25.0.2/lib",
                "--add-modules",
                "javafx.controls",
                "${file}"
            ]
        },
        {
            "label": "Run JavaFX",
            "type": "shell",
            "command": "java",
            "args": [
                "--module-path",
                "/home/kagit/javafx-sdk-25.0.2/lib",
                "--add-modules",
                "javafx.controls",
                "${fileBasenameNoExtension}"
            ],
            "dependsOn": "Compile",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "type": "java (build)",
            "paths": [
                "${workspace}"
            ],
            "isFullBuild": false,
            "group": "build",
            "problemMatcher": [],
            "label": "java (build): Build Workspace",
            "detail": "$(tools) Build all the Java projects in workspace."
        }
    ]
}